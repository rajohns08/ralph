# Initialize collab file with topic
init_collab() {
    local topic="$1"
    mkdir -p "$RALPH_DIR"
    echo "# Collab: $topic" > "$COLLAB_FILE"
    echo "" >> "$COLLAB_FILE"
}

# Run a collab turn for any tool
run_collab_turn() {
    local tool="$1"
    local topic="$2"
    local turn_num="$3"
    local user_args="${4:-}"
    local role="${5:-}"

    local tool_name
    tool_name=$(get_tool_display_name "$tool")
    local tool_color
    tool_color=$(get_tool_color "$tool")

    # Build label: "Builder (Copilot)" or just "Copilot" if no role given
    local label="$tool_name"
    if [[ -n "$role" ]]; then
        label="$role ($tool_name)"
    fi

    # Determine the other participant's label
    local other_label
    if [[ "$role" == "Builder" ]]; then
        other_label="Reviewer ($(get_tool_display_name "$REVIEWER_TOOL"))"
    else
        other_label="Builder ($(get_tool_display_name "$BUILDER_TOOL"))"
    fi

    local start_time
    start_time=$(date +%s)

    log_section "${label} - Turn $turn_num"

    local conversation
    conversation=$(cat "$COLLAB_FILE")

    local collab_prompt="You are the $role, participating in a collaborative discussion with $other_label.

TOPIC: $topic

CONVERSATION SO FAR:
$conversation

Instructions:
1. Read the conversation above and consider the topic
2. Provide your thoughts, analysis, and perspective
3. Respond to any points raised by the other participant
4. Append your response to $COLLAB_FILE as a new section with the header: ## $label (Turn $turn_num)
5. At the very end of your appended section, on its own line, write exactly AGREE if you agree with the current consensus/direction, or DISAGREE if you think more discussion is needed

Your response should be substantive but concise. Focus on reaching agreement."

    log "=== ${tool_name} COLLAB PROMPT ==="
    echo "$collab_prompt" | tee -a "$LOG_FILE"
    log "=== END ${tool_name} COLLAB PROMPT ==="

    echo -e "${tool_color}--- ${label} Output Start ---${NC}"
    echo "--- ${label} Output Start ---" >> "$LOG_FILE"

    local tmpfile
    tmpfile=$(mktemp)
    local debug_file="$RALPH_DIR/debug_${tool}_stream.json"
    trap "rm -f $tmpfile" RETURN

    if run_tool_exec "$tool" "$collab_prompt" "$tmpfile" "$debug_file" "$user_args"; then

        echo ""
        echo -e "${tool_color}--- ${label} Output End ---${NC}"
        echo "--- ${label} Output End ---" >> "$LOG_FILE"

        display_tool_usage "$tool" "$tmpfile"

        log "${label} turn $turn_num complete (total: $(get_total_elapsed))"
        rm -f "$debug_file"
        return 0
    else
        echo ""
        echo -e "${tool_color}--- ${label} Output End ---${NC}"
        echo "--- ${label} Output End ---" >> "$LOG_FILE"
        log "${label} turn $turn_num failed (total: $(get_total_elapsed))"
        rm -f "$debug_file"
        return 1
    fi
}

# Check if the last two sections in the collab file both end with AGREE
check_collab_agreement() {
    local last_two_verdicts
    last_two_verdicts=$(awk '
        /^## (Builder|Reviewer) / {
            if (verdict != "") { print verdict; verdict="" }
        }
        /^AGREE$/ { verdict="AGREE" }
        /^DISAGREE$/ { verdict="DISAGREE" }
        END { if (verdict != "") print verdict }
    ' "$COLLAB_FILE" | tail -2)

    local count
    count=$(echo "$last_two_verdicts" | wc -l | tr -d ' ')

    if [[ "$count" -ge 2 ]]; then
        local agrees
        agrees=$(echo "$last_two_verdicts" | grep -c "^AGREE$" || true)
        if [[ "$agrees" -eq 2 ]]; then
            return 0
        fi
    fi
    return 1
}

# Generate final summary after agreement using the builder tool
run_collab_summary() {
    local topic="$1"

    local tool="$BUILDER_TOOL"
    local tool_name
    tool_name=$(get_tool_display_name "$tool")
    local tool_color
    tool_color=$(get_tool_color "$tool")

